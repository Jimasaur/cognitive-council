{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cognitive-council.local.council_result.v0",
  "title": "Council result",
  "type": "object",
  "required": ["runtime", "task_id", "profile", "decision", "requires_confirmation", "confidence", "flags", "slice_outputs", "next_action"],
  "additionalProperties": true,
  "properties": {
    "runtime": {"type": "string"},
    "task_id": {"type": "string"},
    "profile": {"type": "string"},
    "decision": {"type": "string"},
    "requires_confirmation": {"type": "boolean"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "flags": {"type": "array", "items": {"type": "string"}},
    "slice_outputs": {"type": "array"},
    "next_action": {
      "type": "object",
      "required": ["type", "message"],
      "properties": {
        "type": {"type": "string"},
        "message": {"type": "string"}
      }
    }
  }
}
